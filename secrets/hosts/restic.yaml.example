# Restic multi-target backup credentials
# To create the actual encrypted file:
# 1. Copy this to restic.yaml in each host's secrets directory
#    e.g., secrets/hosts/hephaestus/restic.yaml
# 2. Encrypt with: sops -e -i secrets/hosts/hephaestus/restic.yaml
# 3. Edit with: sops secrets/hosts/hephaestus/restic.yaml

# B2 Target (Backblaze B2)
# Recommended approach: One bucket for all workstations (e.g., "gorschu-backup-workstations")
# Each host uses a separate repository directory within the bucket (e.g., hephaestus, apollo)
# This means the same credentials can be used across all hosts - just copy this file to each host's secrets directory
# Get these from Backblaze B2:
# 1. Create a B2 bucket (e.g., "gorschu-backup-workstations")
# 2. Create an Application Key with access to that bucket
restic-b2-password: "your-strong-restic-password-here"
restic-b2-account-id: "your-b2-account-id-here"
restic-b2-account-key: "your-b2-application-key-here"

# S3 Target (AWS S3, Scaleway, or any S3-compatible provider)
# For AWS S3: Get from IAM console
# For Scaleway: Get from Scaleway console > Object Storage
# For others: Get from your provider's API credentials section
# Note: The target name (e.g., "scaleway", "aws") is just a label - use backend = "s3" for all
restic-scaleway-password: "your-strong-restic-password-here"
restic-scaleway-access-key-id: "your-access-key-here"
restic-scaleway-secret-access-key: "your-secret-key-here"

# Additional S3 target example (if you want multiple S3 providers)
# restic-aws-password: "your-strong-restic-password-here"
# restic-aws-access-key-id: "your-aws-access-key-here"
# restic-aws-secret-access-key: "your-aws-secret-key-here"

# Note: Generate strong random passwords with: openssl rand -base64 32
# Each target gets its own password for maximum isolation
